# ============================================================
#  reminders — environment variables
# ============================================================

# --- REQUIRED ---

# Passcode that gates the whole app (page + API). Pick something you can
# type comfortably on your phone. This is the only thing between the
# public URL and your reminders.
APP_PASSWORD=""

# Shared secret that authenticates the cron trigger (GitHub Action /
# external cron) against /api/cron/check. Any random string; set the same
# value here and in your GitHub repo secret.
CRON_SECRET=""


# --- AUTOMATIC (provided by the Neon integration on Vercel) ---
# Locally, pull them with: npx vercel env pull .env.local
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASS@HOST/DB?sslmode=require"


# --- OPTIONAL ---
# Web Push (VAPID) keys are auto-generated and stored in the database on
# first use, so you normally DON'T need to set these. Set them only if you
# want to pin a specific keypair (e.g. to keep existing subscriptions).
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# Contact used in the push payload's VAPID "subject" (mailto: or a URL).
# VAPID_SUBJECT="mailto:you@example.com"
