# --- Base de datos ---
# Dev (SQLite):  file:./dev.db
# Prod (Postgres): postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL="file:./dev.db"

# --- Web Push (VAPID) ---
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# --- Scheduler / cron ---
# Cualquier string aleatorio. El scheduler local y Vercel Cron lo usan para autenticarse.
CRON_SECRET=""

# --- Passcode de acceso ---
# Gatea toda la app (página + API) detrás de este passcode. Elegí algo que
# puedas tipear cómodo en el iPhone.
APP_PASSWORD=""
